generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QuizScore {
  id         String   @id @default(cuid())
  nickname   String   @db.VarChar(24)
  score      Int
  total      Int
  correct    Int
  percentage Int
  ipHash     String?  @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@index([score(sort: Desc), createdAt(sort: Asc)])
  @@index([nickname])
  @@index([ipHash, createdAt])
}
